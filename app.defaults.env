# Public release defaults for the packaged Core Mail app.
# These values are safe to ship. User-specific account IDs, sender addresses,
# API tokens, mailbox URLs, mailbox secrets, and OAuth tokens stay in the local
# app-data .env file.
CLOUDFLARE_OAUTH_CLIENT_ID=994d0f5c3340b4928dddaeeeaae50100
CLOUDFLARE_OAUTH_REDIRECT_URI=http://127.0.0.1:8899/api/oauth/callback
CLOUDFLARE_OAUTH_SCOPES=email-sending.write memberships.read user-details.read
