CLOUDFLARE_API_TOKEN=replace-me
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
DEFAULT_FROM=inbox@example.com
DEFAULT_TO=recipient@example.com

# Optional Cloudflare OAuth for the desktop Connect button. The client ID is
# public; never ship a client secret in the Mac app.
CLOUDFLARE_OAUTH_CLIENT_ID=
CLOUDFLARE_OAUTH_REDIRECT_URI=http://127.0.0.1:8899/api/oauth/callback
CLOUDFLARE_OAUTH_SCOPES=

# Local web-server options. The Mac app defaults to 8899 so Cloudflare OAuth
# can use a stable localhost callback, and stores its real config in the user's
# app data directory instead of this repo.
PORT=8899
HOST=127.0.0.1
MAILBOX_WORKER_URL=https://better-email-routing-inbox.example.workers.dev
MAILBOX_API_SECRET=replace-me

# Optional extra senders. Each sender can use its own Cloudflare account/token.
SENDER_PROFILE_1_FROM=gianni@example.com
SENDER_PROFILE_1_LABEL="Gianni at Example"
SENDER_PROFILE_1_CLOUDFLARE_ACCOUNT_ID=OTHER_CLOUDFLARE_ACCOUNT_ID
SENDER_PROFILE_1_CLOUDFLARE_API_TOKEN=replace-me
