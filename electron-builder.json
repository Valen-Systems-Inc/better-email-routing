{
  "appId": "com.valensystems.betteremailrouting",
  "productName": "Better Email Routing",
  "asar": true,
  "npmRebuild": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**",
    "public/**",
    "worker/**",
    "server.js",
    "package.json",
    "README.md",
    "STARTUP.md",
    "docs/**",
    ".env.example"
  ],
  "mac": {
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "artifactName": "${productName}-${version}-${arch}.${ext}"
}
