{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Core Mail",
  "version": "1.0.6",
  "identifier": "com.valensystems.coremail",
  "build": {
    "beforeBuildCommand": "npm run sidecar:build",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns"],
    "externalBin": ["binaries/core-mail-server"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  }
}
